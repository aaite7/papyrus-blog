<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
                            http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">
  <!-- 
    Sitemap for Minimalist Blog
    更新时间：2026-06-09
    使用说明：
    1. 在发布新文章后更新此文件
    2. 提交到 Google Search Console 和 Bing Webmaster Tools
    3. 建议每 7 天更新一次
  -->
  
  <!-- 首页 -->
  <url>
    <loc>https://yourdomain.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
    <lastmod>2026-06-09</lastmod>
  </url>
  
  <!-- 管理页面 -->
  <url>
    <loc>https://yourdomain.com/admin</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  
  <!-- 登录页面 -->
  <url>
    <loc>https://yourdomain.com/login</loc>
    <changefreq>monthly</changefreq>
    <priority>0.1</priority>
  </url>
  
  <!-- 
    文章页面示例 - 请在发布文章后添加
    格式说明：
    <url>
      <loc>https://yourdomain.com/post/文章 ID</loc>
      <changefreq>monthly</changefreq>
      <priority>0.8</priority>
      <lastmod>YYYY-MM-DD</lastmod>
    </url>
  -->
  
  <!-- 示例文章页面 -->
  <url>
    <loc>https://yourdomain.com/post/sample-post-1</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
    <lastmod>2026-06-01</lastmod>
  </url>
  
  <url>
    <loc>https://yourdomain.com/post/sample-post-2</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
    <lastmod>2026-05-15</lastmod>
  </url>
  
</urlset>
